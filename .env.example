API_HOST=0.0.0.0
API_PORT=8000

WEB_API_BASE_URL=http://localhost:8000

# Standard model harness configuration.
# Supported providers in v0.2: ollama, openai.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3

# Ollama provider settings.
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI provider settings. Keep OPENAI_API_KEY empty unless using OpenAI.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=scriptura_sources
INGEST_SOURCE_DIRS=data/sample/sources,data/open/sources,data/custom/sources

DEFAULT_RESPONSE_LANGUAGE=pt-BR
DEFAULT_SOURCE_LANGUAGES=pt-BR,en,grc,hbo
